{
  "manifest_version": 3,
  "name": "BULK Checkbox Checker",
  "version": "1.0",
  "description": "Check/uncheck all checkboxes in a selected container. Click extension icon to toggle.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BULK Checkbox Checker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}