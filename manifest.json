{
  "manifest_version": 3,
  "name": "BULK Checkbox Checker",
  "version": "1.1",
  "description": "Check/uncheck all checkboxes in a selected container. Click extension icon to toggle.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BULK Checkbox Checker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}